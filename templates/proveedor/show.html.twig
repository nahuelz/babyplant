{% extends 'base.html.twig' %}

{% import 'app/_macro_show.html.twig' as macro_show %}

{% block stylesheets %}
    {{ parent() }}

    <style type="text/css">
        .card.card-detail .card-header {
            padding: 15px;
            background-color: #f5f5f5;
        }

        .card.card-detail {
            margin-bottom: 20px;
        }
        .card.card-custom{
            box-shadow: 0px 0px 20px 0px gray;
        }
    </style>
{% endblock stylesheets %}

{% block body %}

    <div class="card card-detail">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <h4 class="card-title mb-0 mr-3">Detalles del proveedor {{ proveedor }}</h4>
                </div>
                <div>

                    <a href="{{ path('proveedor_edit', {'id': proveedor.id}) }}" class="btn btn-primary font-weight-bolder">
                        <i class="la la-pen"></i>
                        Editar
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="row">
                {{ macro_show._show_detail('Nombre', proveedor.nombre, 'col-md-4') }}
                {{ macro_show._show_detail('CUIT/CUIL', proveedor.cuit|default('-'), 'col-md-4') }}
                {{ macro_show._show_detail('Email', proveedor.email|default('-'), 'col-md-4') }}
                {{ macro_show._show_detail('Teléfono', proveedor.telefono|default('-'), 'col-md-4') }}
                {{ macro_show._show_detail('Dirección', proveedor.direccion|default('-'), 'col-md-4') }}
                {{ macro_show._show_detail('Condición IVA', proveedor.condicionIva|default('-'), 'col-md-4') }}
            </div>
            <div class="row">
                {{ macro_show._show_detail('Observaciones', proveedor.observaciones|default('-'), 'col-md-12') }}
            </div>

        </div>
    </div>

    {# Cuenta Corriente #}
    {% if proveedor.cuentaCorrienteProveedor %}
        <div class="card card-detail">
            <div class="card-header">
                <h4 class="card-title">Cuenta Corriente</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card shadow-sm {{ proveedor.cuentaCorrienteProveedor.saldoArs < 0 ? 'border-danger' : 'border-success' }}">
                            <div class="card-body py-4">
                                <small class="font-size-16 text-uppercase">Saldo en ARS</small>
                                <div class="display-4 font-weight-bold {{ proveedor.cuentaCorrienteProveedor.saldoArs < 0 ? 'text-danger' : 'text-success' }}">
                                    ${{ proveedor.cuentaCorrienteProveedor.saldoArs|number_format(2, ',', '.') }}
                                </div>
                                <small class="text-muted">
                                    {% if proveedor.cuentaCorrienteProveedor.saldoArs < 0 %}
                                        Deuda con el proveedor
                                    {% else %}
                                        Saldo a favor
                                    {% endif %}
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card shadow-sm {{ proveedor.cuentaCorrienteProveedor.saldoUsd < 0 ? 'border-danger' : 'border-success' }}">
                            <div class="card-body py-4">
                                <small class="font-size-16 text-uppercase">Saldo en USD</small>
                                <div class="display-4 font-weight-bold {{ proveedor.cuentaCorrienteProveedor.saldoUsd < 0 ? 'text-danger' : 'text-success' }}">
                                    US$ {{ proveedor.cuentaCorrienteProveedor.saldoUsd|number_format(2, ',', '.') }}
                                </div>
                                <small class="text-muted">
                                    {% if proveedor.cuentaCorrienteProveedor.saldoUsd < 0 %}
                                        Deuda con el proveedor
                                    {% else %}
                                        Saldo a favor
                                    {% endif %}
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="row">
        <div class="col-md-6">
            {# Facturas #}
            <div class="card card-detail">
                <div class="card-header d-flex justify-content-between align-items-center padding-10">
                    <div class="card-title mb-0">
                        <h4 class="card-label mb-0">Facturas Generadas</h4>
                    </div>
                    <div class="card-toolbar">
                        <button type="button" class="btn btn-primary btn-sm font-weight-bolder" data-toggle="modal" data-target="#modalAgregarFactura">
                            <i class="la la-plus"></i> Nueva Factura
                        </button>
                    </div>
                </div>
                <div class="card-body padding-20">
                    <div class="row">
                        <div class="col-md-12">
                            {% if facturas|length > 0 %}
                                <div class="table-scrollable" style="border: none; overflow-y: scroll; height: 400px;">
                                    <table class="table table-striped table-bordered table-advance table-hover" style="border: 1px solid #ddd;">
                                        <thead>
                                            <tr>
                                                <th class="text-center nowrap">Número</th>
                                                <th class="text-center nowrap">Fecha</th>
                                                <th class="text-center nowrap">Moneda</th>
                                                <th class="text-center nowrap">Total</th>
                                                <th class="text-center nowrap"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for factura in facturas %}
                                                <tr>
                                                    <td class="v-middle nowrap text-center">{{ factura.numeroFactura }}</td>
                                                    <td class="v-middle nowrap text-center">{{ factura.fecha ? factura.fecha|date('d/m/Y') : '-' }}</td>
                                                    <td class="v-middle nowrap text-center">
                                                        <span class="label label-inline font-weight-bold {{ factura.tipoMoneda == 'USD' ? 'label-warning' : 'label-primary' }}">
                                                            {{ factura.tipoMoneda }}
                                                        </span>
                                                    </td>
                                                    <td class="v-middle nowrap text-center">{{ factura.tipoMoneda == 'USD' ? 'US$' : '$' }} {{ factura.getTotal()|number_format(2, ',', '.') }}</td>
                                                    <td class="text-center dt-acciones">
                                                        <div class="dropdown dropdown-inline">
                                                            <button type="button" class="btn btn-light-primary btn-icon btn-sm" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                                <i class="ki ki-bold-more-hor"></i>
                                                            </button>
                                                            <div class="dropdown-menu">
                                                                <a href="{{ path('factura_show', {'id': factura.id}) }}" class="dropdown-item">
                                                                    <i class="la la-search" style="margin-right: 5px;"></i> Ver Factura
                                                                </a>
                                                                <a href="#" class="dropdown-item editar-factura-link"
                                                                   data-toggle="modal" data-target="#modalAgregarFactura"
                                                                   data-factura-id="{{ factura.id }}">
                                                                    <i class="la la-pen" style="margin-right: 5px;"></i> Editar
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <div class="note bg-grey-cararra font-size-13">
                                    No hay facturas registradas para este proveedor.
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Pagos #}
        <div class="col-md-6">
            <div class="card card-detail">
                <div class="card-header d-flex justify-content-between align-items-center padding-10">
                    <div class="card-title mb-0">
                        <h4 class="card-label mb-0">Pagos Realizados</h4>
                    </div>
                    <div class="card-toolbar">
                        <a href="{{ path('pagoproveedor_new', {'id': proveedor.id}) }}" class="btn btn-primary btn-sm">
                            <i class="la la-plus"></i>
                            Nuevo Pago
                        </a>
                    </div>
                </div>
                <div class="card-body padding-20">
                    <div class="row">
                        <div class="col-md-12">
                            {% if pagos|length > 0 %}
                                <div class="table-scrollable" style="border: none; overflow-y: scroll; height: 400px;">
                                    <table class="table table-striped table-bordered table-advance table-hover" style="border: 1px solid #ddd;">
                                        <thead>
                                            <tr>
                                                <th class="text-center nowrap">Comprobante</th>
                                                <th class="text-center nowrap">Fecha</th>
                                                <th class="text-center nowrap">Moneda</th>
                                                <th class="text-center nowrap">Importe</th>
                                                <th class="text-center nowrap">Medio de Pago</th>
                                                <th class="text-center nowrap"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for pago in pagos %}
                                                <tr>
                                                    <td class="v-middle nowrap text-center">{{ pago.numeroComprobante|default('-') }}</td>
                                                    <td class="v-middle nowrap text-center">{{ pago.fechaPago ? pago.fechaPago|date('d/m/Y') : '-' }}</td>
                                                    <td class="v-middle nowrap text-center">
                                                        <span class="label label-inline font-weight-bold {{ pago.tipoMoneda == 'USD' ? 'label-warning' : 'label-primary' }}">
                                                            {{ pago.tipoMoneda }}
                                                        </span>
                                                    </td>
                                                    <td class="v-middle nowrap text-center">{{ pago.tipoMoneda == 'USD' ? 'US$' : '$' }} {{ pago.getMonto()|number_format(2, ',', '.') }}</td>
                                                    <td class="v-middle nowrap text-center">{{ pago.modoPago|default('-') }}</td>
                                                    <td class="text-center dt-acciones">
                                                        <div class="dropdown dropdown-inline">
                                                            <button type="button" class="btn btn-light-primary btn-icon btn-sm" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                                <i class="ki ki-bold-more-hor"></i>
                                                            </button>
                                                            <div class="dropdown-menu">
                                                                <a href="{{ path('pagoproveedor_show', {'id': pago.id}) }}" class="dropdown-item">
                                                                    <i class="la la-search" style="margin-right: 5px;"></i> Ver Pago
                                                                </a>
                                                                <a href="{{ path('pagoproveedor_edit', {'id': pago.id}) }}" class="dropdown-item">
                                                                    <i class="la la-pen" style="margin-right: 5px;"></i> Editar
                                                                </a>
                                                                <a href="{{ path('pagoproveedor_delete', {'id': pago.id}) }}" class="dropdown-item">
                                                                    <i class="la la-trash" style="margin-right: 5px;"></i> Eliminar
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <div class="note bg-grey-cararra font-size-13">
                                    No hay pagos registrados para este proveedor.
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer d-flex justify-content-between">
        <a href="{{ path('proveedor_index') }}" class="btn btn-light-dark font-weight-bold">Volver al listado</a>
    </div>

    <!-- Modal Agregar Factura -->
    <div class="modal fade" id="modalAgregarFactura" tabindex="-1" role="dialog" aria-labelledby="modalAgregarFacturaLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl" role="document" style="max-width: 95vw;">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalAgregarFacturaLabel">Nueva Factura</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <i aria-hidden="true" class="ki ki-close"></i>
                    </button>
                </div>
                <div id="facturaFormContainer">
                    <!-- El formulario se cargará aquí vía AJAX -->
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset(__PREFIX_JAVASCRIPT__ ~ 'config/config-form.js') }}"></script>

    <script>
        $(document).ready(function() {
            $('#modalAgregarFactura').on('show.bs.modal', function(event) {
                var trigger = $(event.relatedTarget);
                var facturaId = trigger.data('factura-id');
                var isEdit = !!facturaId;

                var url = isEdit
                    ? '{{ path('factura_edit_modal', {'id': 'FACTURA_ID'}) }}'.replace('FACTURA_ID', facturaId)
                    : '{{ path('factura_new_modal', {'proveedor_id': proveedor.id}) }}';

                $('#modalAgregarFacturaLabel').text(isEdit ? 'Editar Factura' : 'Nueva Factura');

                $('#facturaFormContainer').html('<div class="text-center p-4"><i class="fas fa-spinner fa-spin"></i> Cargando...</div>');
                $.ajax({
                    url: url,
                    type: 'GET',
                    success: function(response) {

                        $('#facturaFormContainer').html(response);

                        $.getScript('{{ asset(__PREFIX_JAVASCRIPT__ ~ 'app/factura/new.js') }}')
                            .done(function () {

                                initFormValidation();
                                initFacturaDetalleHandler();
                                initMontoFormat();
                                if ($('.tr-factura-detalle').length > 0) {
                                    $('.row-factura-detalle-empty').hide();
                                    $('.row-factura-detalle').show();
                                } else {
                                    $('.row-factura-detalle-empty').hide();
                                }
                                initSelect2();
                                calcularTotal();
                                initBaseSubmitButton();

                            })
                            .fail(function () {
                                console.error('No se pudo cargar factura/new.js');
                            });
                    },
                    error: function() {
                        $('#facturaFormContainer').html('<div class="alert alert-danger m-3">Error al cargar el formulario.</div>');
                    }
                });
            });
        });
    </script>

{% endblock %}
