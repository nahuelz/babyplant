{% extends 'base.html.twig' %}

{% import 'app/_macro_show.html.twig' as macro_show %}

{% block body %}

    <div class="card card-custom">
        <div class="card-header">
            <div class="card-title">
				<span class="card-icon">
					<i class="flaticon-search text-primary"></i>
				</span>
                <h3 class="card-label">Detalles del motivo eliminacion
                    {{ tipo_motivo_eliminacion }}</h3>
            </div>
            <div class="card-toolbar">
                <!--begin::Button-->
                <a href="{{ path('app_tipo_motivo_eliminacion_edit', {'id': tipo_motivo_eliminacion.id}) }}" class="btn btn-primary font-weight-bolder">
                    <i class="la la-pen"></i>
                    Editar
                </a>
                <!--end::Button-->
            </div>
        </div>

        <div class="card-body">
            <div class="row">
                {{ macro_show._show_detail('Nombre', tipo_motivo_eliminacion.nombre, 'col-md-4') }}
                {{ macro_show._show_detail('Habilitado', tipo_motivo_eliminacion.habilitado == 1 ? 'Si' : 'No', 'col-md-4') }}
            </div>

        </div>
        <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('tipomotivoeliminacion_index') }}" class="btn btn-light-dark font-weight-bold">Volver al listado</a>
        </div>

    </div>


{% endblock %}
