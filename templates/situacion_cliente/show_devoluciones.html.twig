<div class="card card-detail">
    <div class="card-header d-flex justify-content-between align-items-center padding-10">
        <div class="card-title mb-0">
            <h4 class="card-label mb-0">Devoluciones</h4>
        </div>
        <div class="card-toolbar">
            <a href="{{ path('devolucion_new') }}" class="btn btn-primary btn-sm">
                <i class="la la-plus"></i>
                Nueva Devolución
            </a>
        </div>
    </div>
    <div class="card-body padding-1">
        <div class="tab-content">
            <div class="tab-pane active" id="portlet_devolucion_listado">
                <div class="portlet-body padding-0">
                    {% if devoluciones is not empty %}
                        <div class="row">
                            <div class="col-md-12">
                                <div class="table-scrollable" style="border: none;overflow-y:scroll; height:400px;">
                                    <table class="table table-striped table-bordered table-advance table-hover" style="border: 1px solid #ddd;">
                                        <thead>
                                        <tr>
                                            <th class="text-center nowrap">Devolución</th>
                                            <th class="text-center nowrap">Producto</th>
                                            <th class="text-center nowrap">Bandejas</th>
                                            <th class="text-center nowrap">Fecha</th>
                                            <th class="text-center nowrap">Observación</th>
                                            <th class="text-center nowrap"></th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {% for devolucion in devoluciones %}
                                            <tr>
                                                <td class="v-middle nowrap text-center">
                                                    Devolución N° {{ devolucion.id }}
                                                </td>
                                                <td class="v-middle nowrap text-center">
                                                    {{ devolucion.pedidoProducto.getNombreCompleto|default('-') }}
                                                </td>
                                                <td class="v-middle nowrap text-center">
                                                    {{ devolucion.cantidadBandejas|default('-') }}
                                                </td>
                                                <td class="v-middle nowrap text-center">
                                                    {{ devolucion.fechaDevolucion is not null ? devolucion.fechaDevolucion|date('d/m/Y') : '-' }}
                                                </td>
                                                <td class="v-middle nowrap text-center">
                                                    {{ devolucion.observacion|default('-') }}
                                                </td>
                                                <td class=" text-center dt-acciones">
                                                    <div class="dropdown dropdown-inline">
                                                        <button type="button" class="btn btn-light-primary btn-icon btn-sm" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                            <i class="ki ki-bold-more-hor"></i>
                                                        </button>
                                                        <div class="dropdown-menu">
                                                            <a href="{{ path('devolucion_show',{id: devolucion.id}) }}" class="dropdown-item">
                                                                <i class="la la-search" style="margin-right: 5px;"></i> Ver Devolución
                                                            </a>
                                                            <a href="{{ path('devolucion_edit',{id: devolucion.id}) }}" class="dropdown-item">
                                                                <i class="la la-edit" style="margin-right: 5px;"></i> Editar
                                                            </a>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="row row-dictado-empty margin-top-20">
                            <div class="col-md-12">
                                <div class="note bg-grey-cararra font-size-13">
                                    El cliente no presenta devoluciones registradas.
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
