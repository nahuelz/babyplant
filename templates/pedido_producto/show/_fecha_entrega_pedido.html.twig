<div class="col-md-4">
    <div class="d-flex align-items-center mb-10 fecha-entrega-pedido">
        <div class="symbol symbol-40 symbol-light-primary mr-5">
            <span class="symbol-label">
                <span class="svg-icon svg-icon-xl svg-icon-primary">
                    <i class="fas fa-calendar-alt icon-2x text-dark"></i>
                </span>
            </span>
        </div>
        <div class="d-flex flex-column font-weight-bold">

            <!-- LABEL (más suave) -->
            <span class="text-muted text-hover-primary mb-1 font-size-lg">
                FECHA ENTREGA SOLICITADA
            </span>

            <!-- VALOR (más protagonista) -->
            <span class="text-dark font-weight-bold font-size-h6 fecha-entrega">
                {{ entity.fechaEntregaPedidoReal is not null ? entity.fechaEntregaPedidoReal|date('d/m/Y') : entity.fechaEntregaPedido|date('d/m/Y') }}
            </span>

            <span class="text-muted fecha-entrega-hidden" style="display: none">{{ entity.fechaEntregaPedidoReal is not null ? entity.fechaEntregaPedidoReal|date('Y-m-d') : entity.fechaEntregaPedido|date('Y-m-d') }}</span>

        </div>
    </div>
</div>