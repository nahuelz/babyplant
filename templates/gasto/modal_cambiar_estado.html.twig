<div class="modal fade" id="modalCambiarEstado" tabindex="-1" role="dialog" aria-labelledby="modalCambiarEstadoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <form id="formCambiarEstado" method="post" action="{{ path('gasto_cambiar_estado', {'id': gasto.id}) }}">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalCambiarEstadoLabel">
                        <i class="la la-exchange"></i> Cambiar estado del gasto N° {{ gasto.id }}
                    </h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <i aria-hidden="true" class="ki ki-close"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label class="control-label">Estado actual</label>
                        <input type="text" class="form-control" value="{{ gasto.estadoGasto.nombre|default('Sin estado') }}" disabled>
                    </div>
                    <div class="form-group">
                        <label class="control-label" for="cambiar_estado_select">Nuevo estado <span class="text-danger">*</span></label>
                        <select id="cambiar_estado_select" name="id_estado" class="form-control" required>
                            <option value="">Seleccionar...</option>
                            {% for estado in estados %}
                                {% if gasto.estadoGasto is null or estado.id != gasto.estadoGasto.id %}
                                    <option value="{{ estado.id }}">{{ estado.nombre }}</option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="control-label" for="motivo">Motivo</label>
                        <textarea id="motivo" name="motivo" class="form-control" rows="3">Cambio manual de estado</textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light-dark font-weight-bold" data-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning font-weight-bold">
                        <i class="la la-save"></i> Confirmar cambio
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

