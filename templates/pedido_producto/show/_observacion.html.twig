<div class="col-md-4">
    <div class="d-flex align-items-center mb-10 observacion">
        <div class="symbol symbol-40 symbol-light-primary mr-5">
            <span class="symbol-label">
                <span class="svg-icon svg-icon-xl svg-icon-primary">
                    <i class="fas fa-comment icon-2x text-dark"></i>
                </span>
            </span>
        </div>
        <div class="d-flex flex-column font-weight-bold">
            <span class="text-muted text-hover-primary mb-1 font-size-lg">OBSERVACIÓN</span>
            <span class="text-dark font-weight-bold font-size-h6 observacion-text" style="color: red !important;">
                {{ entity.observacion|upper|default('-') }}
            </span>
        </div>
    </div>
</div>

<div class="col-md-4">
    <div class="d-flex align-items-center mb-10 observacion-camara">
        <div class="symbol symbol-40 symbol-light-primary mr-5">
            <span class="symbol-label">
                <span class="svg-icon svg-icon-xl svg-icon-primary">
                    <i class="fas fa-comment icon-2x text-dark"></i>
                </span>
            </span>
        </div>
        <div class="d-flex flex-column font-weight-bold">
            <span class="text-muted text-hover-primary mb-1 font-size-lg">OBSERVACIÓN CÁMARA</span>
            <span class="text-dark font-weight-bold font-size-h6 observacion-camara-text" style="color: red !important;">
                {{ entity.observacionCamara|upper|default('-') }}
            </span>
        </div>
    </div>
</div>