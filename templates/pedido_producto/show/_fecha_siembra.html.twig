<div class="col-md-4">
    <div class="d-flex align-items-center mb-10 fecha-siembra">
        <div class="symbol symbol-40 symbol-light-primary mr-5">
            <span class="symbol-label">
                <span class="svg-icon svg-icon-xl svg-icon-primary">
                    <i class="fas fa-calendar-alt icon-2x text-dark"></i>
                </span>
            </span>
        </div>
        <div class="d-flex flex-column font-weight-bold">
            <span class="text-muted text-hover-primary mb-1 font-size-lg">FECHA SIEMBRA</span>

            <!-- VALOR (más protagonista) -->
            <span class="text-dark font-weight-bold font-size-h6 fecha-siembra">
                {{ entity.fechaSiembraReal is not null ? entity.fechaSiembraReal|date('d/m/Y H:i') : entity.fechaSiembraPlanificacion|date('d/m/Y') }}
            </span>

            <span class="text-muted fecha-siembra-hidden" style="display: none">{{ entity.fechaSiembraReal is not null ? entity.fechaSiembraReal|date('Y-m-d H:i') : entity.fechaSiembraPlanificacion|date('Y-m-d H:i') }}</span>

        </div>
    </div>
</div>