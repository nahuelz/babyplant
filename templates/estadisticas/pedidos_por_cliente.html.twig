{% extends 'base.html.twig' %}

{% block title %}Estadísticas · Pedidos por Cliente{% endblock %}

{% block body %}
    <div class="container mt-4">

        <div class="mb-4">
            <h2 class="fw-bold">📋 Pedidos por cliente</h2>
            <p class="text-muted mb-0">
                Cantidad de pedidos y bandejas realizados por cada cliente en el período seleccionado
            </p>
        </div>

        {# Filtros #}
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Desde</label>
                        <input type="date"
                               name="desde"
                               class="form-control"
                               value="{{ desde|date('Y-m-d') }}">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Hasta</label>
                        <input type="date"
                               name="hasta"
                               class="form-control"
                               value="{{ hasta|date('Y-m-d') }}">
                    </div>

                    <div class="col-md-4 d-flex gap-2">
                        <button class="btn btn-primary w-100">
                            Filtrar
                        </button>
                        <a href="{{ path('estadisticas_pedidos_cliente') }}"
                           class="btn btn-outline-secondary w-100">
                            Limpiar
                        </a>
                    </div>
                </form>
            </div>
        </div>

        {# Grilla #}
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th class="text-center">#</th>
                        <th>Cliente</th>
                        <th class="text-end">Cantidad de productos pedidos</th>
                        <th class="text-end">Total de bandejas</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if resultados is empty %}
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                No hay pedidos en el rango seleccionado
                            </td>
                        </tr>
                    {% else %}
                        {% set total = 0 %}
                        {% for row in resultados %}
                            {% set total = total + row.cantidad %}
                            <tr>
                                <td class="text-center">
                                    {{ (pagina_actual - 1) * 20 + loop.index }}
                                </td>
                                <td>
                                    <strong>{{ row.nombre }} {{ row.apellido }}</strong>
                                </td>
                                <td class="text-end">
                                <span class="badge bg-primary fs-6">
                                    {{ row.cantidad }}
                                </span>
                                </td>
                                <td class="text-end">
                                    <span class="badge bg-success fs-6">
                                        {{ row.total_bandejas|round }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                    </tbody>

                    {% if resultados is not empty %}
                        {% set total_bandejas = 0 %}
                        {% for row in resultados %}
                            {% set total_bandejas = total_bandejas + row.total_bandejas %}
                        {% endfor %}
                        <tfoot class="table-light">
                        <tr>
                            <th></th>
                            <th>Total</th>
                            <th class="text-end">
                                {{ total }}
                            </th>
                            <th class="text-end">
                                {{ total_bandejas }}
                            </th>
                        </tr>
                        </tfoot>
                    {% endif %}
                </table>
            </div>
        </div>

        {# Paginación #}
        {% if total_paginas > 1 %}
            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <nav>
                        <ul class="pagination justify-content-center mb-0">
                            {% set start_page = max(1, pagina_actual - 2) %}
                            {% set end_page = min(total_paginas, pagina_actual + 2) %}
                            
                            {% if pagina_actual > 1 %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('estadisticas_pedidos_cliente', {'desde': desde|date('Y-m-d'), 'hasta': hasta|date('Y-m-d'), 'pagina': pagina_actual - 1}) }}">
                                        &laquo;
                                    </a>
                                </li>
                            {% endif %}
                            
                            {% for page in range(start_page, end_page) %}
                                {% if page == pagina_actual %}
                                    <li class="page-item active">
                                        <span class="page-link">{{ page }}</span>
                                    </li>
                                {% else %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('estadisticas_pedidos_cliente', {'desde': desde|date('Y-m-d'), 'hasta': hasta|date('Y-m-d'), 'pagina': page}) }}">
                                            {{ page }}
                                        </a>
                                    </li>
                                {% endif %}
                            {% endfor %}
                            
                            {% if pagina_actual < total_paginas %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('estadisticas_pedidos_cliente', {'desde': desde|date('Y-m-d'), 'hasta': hasta|date('Y-m-d'), 'pagina': pagina_actual + 1}) }}">
                                        &raquo;
                                    </a>
                                </li>
                            {% endif %}
                        </ul>
                    </nav>
                    
                    <div class="text-center mt-3">
                        <small class="text-muted">
                            Mostrando {{ resultados|length }} de {{ total_resultados }} clientes
                        </small>
                    </div>
                </div>
            </div>
        {% endif %}

    </div>
{% endblock %}
