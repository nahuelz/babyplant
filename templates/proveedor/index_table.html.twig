{
"data": [
{% for entity in entities %}
    [
    "{{ entity.id }}",
    "{{ entity.nombre|default('-') }}",
    "{{ entity.cuit|default('-') }}",
    "{{ entity.email|default('-') }}",
    "{{ entity.telefono|default('-') }}",
    "{{ entity.direccion|default('-') }}",
    "{{ entity.habilitado|boolean_format('-') }}",
    {
    {% if is_granted('ROLE_PROVEEDOR') %}
        "show" : " {{ path( "proveedor_show", { "id": entity.id }) }}"
        ,"edit" : " {{ path( "proveedor_edit", { "id": entity.id }) }}"
        ,"agregarFactura" : " {{ path( "factura_new", { "proveedor_id": entity.id }) }}"
    {% endif %}
    {% if entity.habilitado %}
        ,"deshabilitar": "{{ path('proveedor_habilitar_deshabilitar', { "id": entity.id }) }}"
    {% else %}
        ,"habilitar": "{{ path('proveedor_habilitar_deshabilitar', {"id": entity.id})}}"
    {% endif %}
    }
    ]{{ (loop.last ? '' : ',') }}
{% endfor %}
],
"draw": {{ draw }},
"recordsTotal": {{ totalRows }},
"recordsFiltered": {{ totalFiltered }}
}
