{% extends 'base.html.twig' %}

{% set edit = form.vars.value.id != null %}
{% set entity = form.vars.value %}

{% import 'app/_macro_form.html.twig' as macro_form %}

{% block body %}
    {{ form_start(form, {'attr': {'class' : 'horizontal-form','novalidate': 'novalidate'} }) }}
    {% include ('app/_fields_errors.html.twig') %}

    <div class="card card-custom">
        <div class="card-header">
            <div class="card-title">
				<span class="card-icon">
					<i class="flaticon-search text-primary"></i>
				</span>
                <h3 class="card-label">{% if edit %}Editar Factura{% else %}Nuevo Factura{% endif %}</h3>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                {{ macro_form._new_field(form.numeroFactura, 'col-md-6') }}
                {{ macro_form._new_field(form.fecha, 'col-md-6') }}
            </div>
            <div class="row">
                {{ macro_form._new_field(form.tipoMoneda, 'col-md-6') }}
                <div class="col-md-6" id="tipo-cambio-container" style="display: {% if form.vars.value.tipoMoneda == 'USD' %}block{% else %}none{% endif %};">
                    {{ macro_form._new_field(form.tipoCambio, 'col-md-12') }}
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    {% include 'factura/new.detalle.html.twig' with {'detalleForm': form.detalle, 'entity': entity} %}
                </div>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('factura_index') }}" class="btn btn-light-dark font-weight-bold">Volver</a>
            <button type="submit" id="factura_submit" name="factura[submit]" class="btn btn-light-primary font-weight-bold submit-button">{{ button_label|default('Guardar') }}</button>
        </div>
    </div>

{% endblock %}

{% block javascripts %}

    {{ parent() }}
    <script src="{{ asset(__PREFIX_JAVASCRIPT__ ~ 'config/config-form.js') }}"></script>
    <script src="{{ asset(__PREFIX_JAVASCRIPT__ ~ 'app/factura/new.js') }}"></script>

{% endblock %}