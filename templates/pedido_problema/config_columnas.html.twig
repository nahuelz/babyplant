<div class="portlet light bordered portlet-nivel-1 mr-10" style="padding: 10px; margin-left: 30px; border-radius: 5px; background-color: #F8F9FA">
    <h5 class="text-dark mb-3">
        <i class="la la-columns"></i> Configuración de Columnas
    </h5>
    
    <div class="row">
        <div class="col-md-10">
            <label class="control-label">Columnas a Ocultar</label>
            <select class="form-control" multiple="multiple" id="multiple" style="min-height: 70px; min-width: 100px !important;">
                <option value="1" {% if 1 in columnasOcultas %}selected="selected"{% endif %}>ID Pedido</option>
                <option value="2" {% if 2 in columnasOcultas %}selected="selected"{% endif %}>ID Producto</option>
                <option value="3" {% if 3 in columnasOcultas %}selected="selected"{% endif %}>Fecha Pedido</option>
                <option value="4" {% if 4 in columnasOcultas %}selected="selected"{% endif %}>Producto</option>
                <option value="5" {% if 5 in columnasOcultas %}selected="selected"{% endif %}>Cliente</option>
                <option value="6" {% if 6 in columnasOcultas %}selected="selected"{% endif %}>Bandejas Pedidas</option>
                <option value="7" {% if 7 in columnasOcultas %}selected="selected"{% endif %}>Origen Semillas</option>
                <option value="8" {% if 8 in columnasOcultas %}selected="selected"{% endif %}>Cantidad Semillas</option>
                <option value="9" {% if 9 in columnasOcultas %}selected="selected"{% endif %}>Fecha Siembra</option>
                <option value="10" {% if 10 in columnasOcultas %}selected="selected"{% endif %}>Fecha Entrega</option>
                <option value="11" {% if 11 in columnasOcultas %}selected="selected"{% endif %}>Estado</option>
                <option value="12" {% if 12 in columnasOcultas %}selected="selected"{% endif %}>Dias en camara</option>
                <option value="13" {% if 13 in columnasOcultas %}selected="selected"{% endif %}>Dias en invernaculo</option>
                <option value="14" {% if 14 in columnasOcultas %}selected="selected"{% endif %}>Orden Siembra</option>
                <option value="15" {% if 15 in columnasOcultas %}selected="selected"{% endif %}>Mesada</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-success btn-sm mt-10" id="guardar_columnas" style="min-height: 60px">
                <i class="la la-save"></i>
                Guardar
            </button>
        </div>
    </div>
    
    <div class="row mt-3">
        <div class="col-md-12">
            <small class="text-muted">
                <i class="la la-info-circle"></i> 
                Seleccione las columnas que desea ocultar y haga clic en "Guardar". 
                Los cambios se aplicarán automáticamente al recargar la página.
            </small>
        </div>
    </div>
</div>
