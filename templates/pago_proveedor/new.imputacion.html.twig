{% import 'app/_macro_form.html.twig' as macro_form %}

{% set tieneImputaciones = entity.imputaciones|length > 0 %}

<div class="row row-imputacion-empty margin-top-20" style="display:none;">
    <div class="col-md-12">
        <div class="alert alert-danger" style="background-color: #fbe1e3;color: brown;">
            Debe imputar el pago a al menos una factura.
        </div>
    </div>
</div>

<div class="row-form-imputacion">
    <div class="row align-items-end">
        {{ macro_form._new_field(form.imputacion.factura, 'col-md-6') }}
        {{ macro_form._new_field(form.imputacion.monto, 'col-md-3') }}
        <div class="col-md-3 ml-auto">
            <div class="form-group">
                <button type="button" class="btn btn-success font-weight-bold margin-top-25 link-save-imputacion">
                    IMPUTAR A FACTURA
                </button>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6"></div>
        <div class="col-md-6">
            <small id="imputacion-monto-equivalente" class="text-muted"></small>
        </div>
    </div>
</div>

<div class="col-md-12 row row-imputacion margin-top-15" {{ tieneImputaciones ? '' : 'style="display:none;"' }}>
    <div class="col-md-12">
        <div class="table-scrollable">
            <table class="table table-striped table-bordered table-advance table-hover">
                <thead>
                    <tr>
                        <th class="text-center">Factura</th>
                        <th class="text-center">Moneda</th>
                        <th class="text-center">Monto imputado</th>
                        <th class="nowrap text-center"></th>
                    </tr>
                </thead>
                <tbody class="tbody-imputacion">
                    {% for imputacion in entity.imputaciones %}
                        <tr class="tr-imputacion" data-monto="{{ imputacion.monto }}" data-moneda="{{ imputacion.factura.tipoMoneda }}">
                            {% if imputacion.id %}
                            <td class="hidden">
                                <input type="hidden" name="pago_proveedor[imputaciones][{{ loop.index0 }}][id]" value="{{ imputacion.id }}">
                            </td>
                            {% endif %}
                            <td class="hidden">
                                <input type="hidden" name="pago_proveedor[imputaciones][{{ loop.index0 }}][factura]" value="{{ imputacion.factura.id }}">
                            </td>
                            <td class="hidden">
                                <input type="hidden" name="pago_proveedor[imputaciones][{{ loop.index0 }}][monto]" value="{{ imputacion.monto|number_format(2, ',', '.') }}">
                            </td>

                            <td class="v-middle text-center">{{ imputacion.factura.numeroFactura }}</td>
                            <td class="v-middle text-center">{{ imputacion.factura.tipoMoneda }}</td>
                            <td class="v-middle text-center">{{ imputacion.factura.tipoMoneda == 'USD' ? 'US$' : '$' }} {{ imputacion.monto|number_format(2, ',', '.') }}</td>

                            <td class="text-center v-middle">
                                <a href="#" class="btn btn-sm delete-link-inline link-delete-imputacion tooltips"
                                   data-placement="top" data-original-title="Eliminar">
                                    <i class="fa fa-trash text-danger"></i>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot class="tfoot-imputacion" style="display:none;">
                    <tr class="tr-imputacion-total bg-light font-weight-bold">
                        <td class="v-middle text-center" colspan="2">TOTAL IMPUTADO</td>
                        <td class="v-middle text-center" id="total-imputado-usd">US$0,00</td>
                        <td class="v-middle text-center"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
