{% extends 'base.html.twig' %}

{% import 'app/_macro_show.html.twig' as macro_show %}

{% block body %}

    {% set simboloMoneda = pagoProveedor.tipoMoneda == 'USD' ? 'US$' : '$' %}

    <div class="card card-custom">
        <div class="card-header">
            <div class="card-title">
				<span class="card-icon">
					<i class="flaticon-search text-primary"></i>
				</span>
                <h3 class="card-label">Detalles del pago</h3>
            </div>
            <div class="card-toolbar">
                <a href="{{ path('pago_proveedor_edit', {'id': pagoProveedor.id}) }}" class="btn btn-primary font-weight-bolder">
                    <i class="la la-pen"></i>
                    Editar
                </a>
            </div>
        </div>

        <div class="card-body">
            <div class="row">
                {{ macro_show._show_detail('Proveedor', pagoProveedor.proveedor, 'col-md-3') }}
                {{ macro_show._show_detail('Fecha de Pago', pagoProveedor.fechaPago|date('d/m/Y'), 'col-md-2') }}
                {{ macro_show._show_detail('Modo de Pago', pagoProveedor.modoPago|default('-'), 'col-md-2') }}
                {{ macro_show._show_detail('N° Comprobante', pagoProveedor.numeroComprobante|default('-'), 'col-md-2') }}
                {{ macro_show._show_detail('Moneda', pagoProveedor.tipoMoneda, 'col-md-1') }}
                {% if pagoProveedor.tipoMoneda == 'USD' %}
                    {{ macro_show._show_detail('Tipo de Cambio', pagoProveedor.tipoCambio ? pagoProveedor.tipoCambio|money_format : 'N/A', 'col-md-2') }}
                {% endif %}
            </div>

            <div class="row mt-4">
                <div class="col-12">
                    <div class="card shadow-sm {{ pagoProveedor.tipoMoneda == 'USD' ? 'border-warning' : 'border-success' }}" style="max-width: 300px;">
                        <div class="card-body py-4">
                            <small class="font-size-16 text-uppercase">Monto Pagado</small>
                            <div class="display-4 font-weight-bold text-success">
                                {{ simboloMoneda }} {{ pagoProveedor.getMonto()|number_format(2, ',', '.') }}
                            </div>
                            {% if pagoProveedor.tipoMoneda == 'USD' and pagoProveedor.tipoCambio %}
                                <small class="text-muted">
                                    Equivalente ARS: $ {{ (pagoProveedor.getMonto() * pagoProveedor.tipoCambio)|number_format(2, ',', '.') }}
                                </small>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            {% if pagoProveedor.observaciones %}
                <div class="row mt-4">
                    {{ macro_show._show_detail('Observaciones', pagoProveedor.observaciones, 'col-md-12') }}
                </div>
            {% endif %}
        </div>

        <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('pagoproveedor_index') }}" class="btn btn-light-dark font-weight-bold">Volver al listado</a>
        </div>
    </div>

{% endblock %}
