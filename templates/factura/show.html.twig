{% extends 'base.html.twig' %}

{% import 'app/_macro_show.html.twig' as macro_show %}

{% block body %}

    {% set simboloMoneda = factura.tipoMoneda == 'USD' ? 'US$' : '$' %}

    <div class="card card-custom">
        <div class="card-header">
            <div class="card-title">
				<span class="card-icon">
					<i class="flaticon-search text-primary"></i>
				</span>
                <h3 class="card-label">Detalles factura {{ factura.getTotalPagado }}</h3>
                {% if factura.estadoFactura %}
                    <span class="label label-inline font-weight-bold ml-3 {{ factura.estadoFactura.color }}"
                          style="color: #000000;">
                        {{ factura.estadoFactura.nombre }}
                    </span>
                {% endif %}
            </div>
                <div class="card-toolbar">
                    <!--begin::Button-->
                    <a href="{{ path('factura_edit', {'id': factura.id}) }}" class="btn btn-primary font-weight-bolder">
                        <i class="la la-pen"></i>
                        Editar
                    </a>
                    <!--end::Button-->
                </div>
        </div>

        <div class="card-body">
            <div class="row">
                {{ macro_show._show_detail('Número de Factura', factura.numeroFactura, 'col-md-2') }}
                {{ macro_show._show_detail('Fecha', factura.fecha|date('d/m/Y'), 'col-md-2') }}
                {{ macro_show._show_detail('Moneda', factura.tipoMoneda, 'col-md-2') }}
                {{ macro_show._show_detail('Tipo de Cambio', factura.tipoCambio ? factura.tipoCambio|money_format : 'N/A', 'col-md-2') }}
                {{ macro_show._show_detail('Monto total (ARS)', factura.getMontoARS()|money_format, 'col-md-2') }}
                {{ macro_show._show_detail('Monto total (USD)', factura.getMontoUSD()|money_format, 'col-md-2') }}
            </div>
            
            <div class="row mt-4">
                <div class="col-12">
                    <h5 class="mb-3">Detalles de la Factura</h5>
                    {% if factura.detalles|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Grupo</th>
                                        <th>Concepto</th>
                                        <th>Subconcepto</th>
                                        <th>Descripción</th>
                                        <th class="text-center">Cantidad</th>
                                        <th class="text-right">Precio Unitario</th>
                                        <th class="text-right">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for detalle in factura.detalles %}
                                        <tr>
                                            <td>{{ detalle.tipoGrupo ?: '-' }}</td>
                                            <td>{{ detalle.concepto }}</td>
                                            <td>{{ detalle.subConcepto ?: '-' }}</td>
                                            <td>{{ detalle.descripcion ?: '-' }}</td>
                                            <td class="text-center">{{ detalle.cantidad ?: '-' }}</td>
                                            <td class="text-right">{{ detalle.precioUnitario is not null ? detalle.precioUnitario|money_format(2, simboloMoneda) : '-' }}</td>
                                            <td class="text-right font-weight-bold">{{ detalle.montoTotal|money_format(2, simboloMoneda) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                                <tfoot>
                                    <tr class="table-active">
                                        <td colspan="6" class="text-right font-weight-bold">Total:</td>
                                        <td class="text-right font-weight-bold">{{ factura.getTotal()|money_format(2, simboloMoneda) }}</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    {% else %}
                        <div class="alert alert-warning">
                            <i class="la la-exclamation-triangle"></i>
                            Esta factura no tiene detalles configurados.
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12">
                    <h5 class="mb-3">Pagos Realizados</h5>
                    {% if imputaciones|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Fecha de Pago</th>
                                        <th>Modo de Pago</th>
                                        <th>Moneda</th>
                                        <th class="text-right">Monto Imputado</th>
                                        <th class="text-right">Monto Total del Pago</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for imputacion in imputaciones %}
                                        {% set pago = imputacion.pagoProveedor %}
                                        {% set simboloPago = pago.tipoMoneda == 'USD' ? 'US$' : '$' %}
                                        <tr>
                                            <td>{{ pago.fechaPago|date('d/m/Y') }}</td>
                                            <td>{{ pago.modoPago.nombre|default('-') }}</td>
                                            <td>{{ pago.tipoMoneda }}</td>
                                            <td class="text-right">{{ imputacion.monto|money_format(2, simboloPago) }}</td>
                                            <td class="text-right">{{ pago.monto|money_format(2, simboloPago) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                                <tfoot>
                                    <tr class="table-active">
                                        <td colspan="3" class="text-right font-weight-bold">Total Pagado:</td>
                                        <td class="text-right font-weight-bold">{{ factura.getTotalPagado()|money_format(2, simboloMoneda) }}</td>
                                        <td></td>
                                    </tr>
                                    <tr class="table-info">
                                        <td colspan="3" class="text-right font-weight-bold">Saldo Pendiente:</td>
                                        <td class="text-right font-weight-bold">{{ factura.getSaldoPendienteARS() > 0.01 or factura.getSaldoPendienteUSD() > 0.01 ? (factura.tipoMoneda == 'USD' ? factura.getSaldoPendienteUSD() : factura.getSaldoPendienteARS())|money_format(2, simboloMoneda) : '0,00' }}</td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    {% else %}
                        <div class="alert alert-info">
                            <i class="la la-info-circle"></i>
                            Esta factura no tiene pagos registrados.
                        </div>
                    {% endif %}
                </div>
            </div>

        </div>
        <div class="card-footer d-flex justify-content-between">
            <a href="javascript:void(0)" onclick="history.length > 1 ? history.back() : window.location.href='{{ path('factura_index') }}'" class="btn btn-light-dark font-weight-bold">Volver</a>
        </div>

    </div>


{% endblock %}
