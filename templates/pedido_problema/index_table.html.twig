{% set EstadoPedidoProducto = 'App\\Entity\\Constants\\ConstanteEstadoPedidoProducto' %}
{% set EN_INVERNACULO = constant(EstadoPedidoProducto ~ '::EN_INVERNACULO') %}
{% set PENDIENTE = constant(EstadoPedidoProducto ~ '::PENDIENTE') %}
{% set PLANIFICADO = constant(EstadoPedidoProducto ~ '::PLANIFICADO') %}
{% autoescape false %}
    {
    "data": [
    {% for entity in entities %}
        [
        "{{ entity.id }}",
        "{{ entity.id }}",
        {
        "idProducto": "{{ entity.idProducto }}",
        "path": "{{ path('pedido_show', { "id": entity.id }) }}",
        "tipoRevision": "{{ entity.tipoRevision|default('') }}",
        "nombreRevision": "{{ entity.nombreRevision|default('') }}",
        "observacionProblema": "{{ entity.observacionProblema|escape_json|default('') }}",
        "solucion": "{{ entity.solucion|default('') }}",
        "observacionSolucion": "{{ entity.observacionSolucion|escape_json|default('') }}",
        "visto": "{{ entity.visto }}"
        },
        "{{ entity.fechaCreacion is not null ? entity.fechaCreacion|date('d/m/Y') : '-' }}",
        {
        "nombreProductoCompleto": "{{ entity.nombreProductoCompleto|default('default') }}",
        "nombreProducto": "{{ entity.nombreProducto|default('default') }}",
        "colorProducto": "{{ entity.colorProducto|default('default') }}"
        },
        {
        "idPedido": "{{ entity.id }}",
        "cantidadBandejasDisponibles": "{{ entity.cantidadBandejasDisponibles == (entity.cantidadBandejasDisponibles|round(0, 'floor')) ? entity.cantidadBandejasDisponibles|number_format(0, '', '') : entity.cantidadBandejasDisponibles }}",
        "nombreCliente": "{{ entity.cliente|default('-') }}",
        "path": "{{ path('situacioncliente_show', { "id": entity.idCliente }) }}"
        },
        "{{ entity.cantidadBandejas == (entity.cantidadBandejas|round(0, 'floor')) ? entity.cantidadBandejas|number_format(0, '', '') : entity.cantidadBandejas }}",
        "{{ entity.origenSemilla|default('-') }}",
        "{{ entity.cantidadSemillas|default('-') }}",
        "{{ entity.fechaSiembraPedido is not null ? entity.fechaSiembraPedido|date('d/m/Y') : '-' }}",
        "{{ entity.fechaEntregaPedido is not null ? entity.fechaEntregaPedido|date('d/m/Y') : '-' }}",
        {
        "estado" : "{{ entity.estado|default('Sin estado') }}",
        "colorEstado" : "{{ entity.colorEstado|default('default') }}"
        },
        "{{ entity.diasEnCamara|default('-') }}",
        "{{ entity.diasEnInvernaculo|default('-') }}",
        "{{ entity.ordenSiembra|default('-') }}",
        "{{ entity.mesada|default('-') }}",
        "{{ entity.codigoSobre|escape_json|raw|default('-') }}",
        "{{ entity.tieneProblema == 1 ? '1' : '0' }}", {# 17 #}
        "{{ entity.tieneSolucion == 1 ? '1' : '0' }}", {# 18 #}
        {
        "show_pedido" : " {{ path( "pedido_show", { "id": entity.id }) }}",
        {% if entity.tieneProblema == 1 %}
            "pedido_producto_quitar_problema": "{{ path( "pedido_producto_quitar_problema", { "id": entity.idProducto })}}",
            "pedido_producto_editar_problema": "{{ path( "pedido_producto_editar_problema", { "id": entity.idProducto })}}",
        {% else %}
            "pedido_producto_marcar_problema": "{{ path( "pedido_producto_marcar_problema", { "id": entity.idProducto })}}",
        {% endif %}
        {% if entity.tieneSolucion == 1 %}
            "pedido_producto_quitar_solucion": "{{ path( "pedido_producto_quitar_solucion", { "id": entity.idProducto })}}",
            "pedido_producto_editar_solucion": "{{ path( "pedido_producto_editar_solucion", { "id": entity.idProducto })}}",
        {% else %}
            "pedido_producto_marcar_solucion": "{{ path( "pedido_producto_marcar_solucion", { "id": entity.idProducto })}}",
        {% endif %}
        "pedido_producto_elimina_bandeja": "{{ path( "pedido_producto_eliminar_bandejas", { "id": entity.idProducto })}}"
        }]
        {{ (loop.last ? '' : ',') }}
    {% endfor %}
    ]
    }
{% endautoescape %}