<div class="col-md-4">
    <div class="d-flex align-items-center mb-10 fecha-entrada">
        <div class="symbol symbol-40 symbol-light-primary mr-5">
            <span class="symbol-label">
                <span class="svg-icon svg-icon-xl svg-icon-primary">
                    <i class="fas fa-calendar-alt icon-2x text-dark"></i>
                </span>
            </span>
        </div>

        <div class="d-flex flex-column font-weight-bold">

            <!-- LABEL (más suave) -->
            <span class="text-muted text-hover-primary mb-1 font-size-lg">
                FECHA ENTRADA A CÁMARA
            </span>

            <!-- VALOR (más protagonista) -->
            <span class="text-dark font-weight-bold font-size-h6 fecha-entrada-camara">
                {{ entity.fechaEntradaCamara is not null ? entity.fechaEntradaCamara|date('d/m/Y H:i') : '-' }}
            </span>

            <!-- valor oculto (lo dejo igual que lo tenías) -->
            <span class="fecha-entrada-camara-hidden" style="display: none">
                {{ entity.fechaEntradaCamara is not null ? entity.fechaEntradaCamara|date('Y-m-d H:i') : '-' }}
            </span>

        </div>
    </div>
</div>