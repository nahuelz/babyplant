{% autoescape false %}
    {
    "data": [
    {% for entity in entities %}
        [
        "{{ entity.id }}",
        "{{ entity.proveedor|upper }}",
        "{{ entity.numeroFactura }}",
        {
            "fechaFormateada": "{{ entity.fecha is not null ? entity.fecha|date('d/m/Y') : '-' }}",
            "fechaOrdenable": "{{ entity.fecha is not null ? entity.fecha|date('Y-m-d') : '' }}"
        },
        "{{ entity.tipoGrupo|upper|default('-') }}",
        "{{ entity.concepto|upper|default('-') }}",
        {
            "montoTotal": "{{ entity.montoTotal }}",
            "tipoMoneda": "{{ entity.tipoMoneda }}"
        },
        {
        "show" : " {{ path( "factura_show", { "id": entity.id }) }}",
        "edit" : " {{ path( "factura_edit", { "id": entity.id }) }}",
        "delete" : " {{ path( "factura_delete", { "id": entity.id }) }}"
        }
        ]{{ (loop.last ? '' : ',') }}
    {% endfor %}
    ]
    }
{% endautoescape %}