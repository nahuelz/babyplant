{% extends 'base.html.twig' %}

{% import 'app/_macro_show.html.twig' as macro_show %}

{% block body %}

    <div class="card card-custom">
        <div class="card-header">
            <div class="card-title">
				<span class="card-icon">
					<i class="flaticon-search text-primary"></i>
				</span>
                <h3 class="card-label">Detalles gasto</h3>
            </div>
            {% if is_granted('ROLE_BANDEJA_EDIT') %}
                <div class="card-toolbar">
                    <!--begin::Button-->
                    <a href="{{ path('gasto_edit', {'id': gasto.id}) }}" class="btn btn-primary font-weight-bolder">
                        <i class="la la-pen"></i>
                        Editar
                    </a>
                    <!--end::Button-->
                </div>
            {% endif %}
        </div>

        <div class="card-body">
            <div class="row">
                {{ macro_show._show_detail('Fecha', gasto.fecha|date('d/m/Y'), 'col-md-3') }}
                {{ macro_show._show_detail('Concepto', gasto.concepto, 'col-md-3') }}
                {{ macro_show._show_detail('Monto', gasto.monto|money_format, 'col-md-3') }}
                {{ macro_show._show_detail('Modo de Pago', gasto.modoPago, 'col-md-3') }}
            </div>

        </div>
        <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('gasto_index') }}" class="btn btn-light-dark font-weight-bold">Volver al listado</a>
        </div>

    </div>


{% endblock %}
