{% import 'app/_macro_form.html.twig' as macro_form %}

{% set tieneFacturaDetalle = entity.detalles|length > 0 %}

<div class="row row-factura-detalle-empty margin-top-20">
    <div class="col-md-12">
        <div class="alert alert-danger alert-form-error" style="background-color: #fbe1e3;color: brown;">
            Debe ingresar al menos un concepto.
        </div>
    </div>
</div>

<div class="row-form-factura-detalle">
<div class="row align-items-end">
    {{ macro_form._new_field(form.detalle.tipoGrupo, 'col-md-2') }}
    {{ macro_form._new_field(form.detalle.concepto, 'col-md-3') }}
    {{ macro_form._new_field(form.detalle.subConcepto, 'col-md-2') }}
    {{ macro_form._new_field(form.detalle.descripcion, 'col-md-2') }}
    {{ macro_form._new_field(form.detalle.cantidad, 'col-md-1') }}
    {{ macro_form._new_field(form.detalle.precioUnitario, 'col-md-2') }}
    <div class="col-md-2 ml-auto">
        <div class="form-group">
            <button class="btn btn-success font-weight-bold margin-top-25 link-save-factura-detalle spinner-primary">
                AGREGAR CONCEPTO
            </button>
        </div>
    </div>
</div>

</div>

<div class="col-md-12 row row-factura-detalle margin-top-15" {{ tieneFacturaDetalle ? '' : 'style="display:none;"' }}">
<div class="col-md-12">
    <div class="table-scrollable">
        <table class="table table-striped table-bordered table-advance table-hover">
            <thead>
            <tr>
                <th class="text-center">Tipo Grupo</th>
                <th class="text-center">Concepto</th>
                <th class="text-center">Subconcepto</th>
                <th class="text-center">Descripción</th>
                <th class="text-center">Cantidad</th>
                <th class="text-center">Precio unitario</th>
                <th class="text-center">Total</th>
                <th class="nowrap text-center"></th>
            </tr>
            </thead>
            <tbody class="tbody-factura-detalle">

            {% for detalle in entity.detalles %}
                <tr class="tr-factura-detalle">
                    {% if detalle.id %}
                    <td class="hidden">
                        <input type="hidden" name="factura[detalles][{{ loop.index0 }}][id]" value="{{ detalle.id }}">
                    </td>
                    {% endif %}
                    <td class="hidden">
                        <input type="hidden" name="factura[detalles][{{ loop.index0 }}][tipoGrupo]" value="{{ detalle.tipoGrupo ? detalle.tipoGrupo.id : '' }}">
                    </td>
                    <td class="hidden">
                        <input type="hidden" name="factura[detalles][{{ loop.index0 }}][concepto]" value="{{ detalle.concepto.id }}">
                    </td>
                    <td class="hidden">
                        <input type="hidden" name="factura[detalles][{{ loop.index0 }}][subConcepto]" value="{{ detalle.subConcepto ? detalle.subConcepto.id : '' }}">
                    </td>
                    <td class="hidden">
                        <input type="hidden" name="factura[detalles][{{ loop.index0 }}][descripcion]" value="{{ detalle.descripcion }}">
                    </td>
                    <td class="hidden">
                        <input type="hidden" name="factura[detalles][{{ loop.index0 }}][cantidad]" value="{{ detalle.cantidad }}">
                    </td>
                    <td class="hidden">
                        <input type="hidden" name="factura[detalles][{{ loop.index0 }}][precioUnitario]" value="{{ detalle.precioUnitario|number_format(2, ',', '.') }}">
                    </td>

                    <td class="v-middle text-center">{{ detalle.tipoGrupo }}</td>
                    <td class="v-middle text-center">{{ detalle.concepto }}</td>
                    <td class="v-middle text-center">{{ detalle.subConcepto }}</td>
                    <td class="v-middle text-center">{{ detalle.descripcion }}</td>
                    <td class="v-middle text-center">{{ detalle.cantidad }}</td>
                    <td class="v-middle text-center">${{ detalle.precioUnitario|number_format(2, ',', '.') }}</td>
                    <td class="v-middle text-center">${{ detalle.montoTotal|number_format(2, ',', '.') }}</td>

                    <td class="text-center v-middle">
                        <a href="#" class="btn btn-sm delete-link-inline link-delete-factura-detalle tooltips"
                           data-placement="top" data-original-title="Eliminar">
                            <i class="fa fa-trash text-danger"></i>
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
</div>
